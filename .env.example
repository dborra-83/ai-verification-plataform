# === Variables de entorno — AI Verification Platform ===
# Copiar a .env y completar con los valores reales

AWS_DEFAULT_REGION=us-east-1
AWS_ACCOUNT_ID=

# Cognito
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=

# S3
UPLOAD_BUCKET_NAME=

# DynamoDB
ANALYSIS_TABLE_NAME=AiVerificationResults

# Bedrock
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# === NUEVAS VARIABLES — Módulo Document Automation ===
TEXTRACT_MODE=sync                    # sync | async (async para PDFs grandes >5 páginas)
DOC_AUTOMATION_TABLE_NAME=DocAutomationHistory
DEMO_DOCS_S3_PREFIX=demo-docs/        # prefijo en S3 para los documentos de ejemplo
MIN_PROMEDIO_THRESHOLD=5.0            # umbral configurable de promedio mínimo
MAX_DOC_AGE_MONTHS=12                 # antigüedad máxima de documentos en meses
